<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAF5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <!-- Kiri: Header -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pemrograman Seluler"
                android:textSize="10sp"
                android:textColor="#1D8A56"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_green"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lembar&#10;Penilaian"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#1A5C3A"
                android:lineSpacingMultiplier="1.1"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generator otomatis&#10;untuk kelas Anda"
                android:textSize="12sp"
                android:textColor="#5D9E7A"
                android:layout_marginBottom="14dp"/>

            <View
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:background="#34C17A"/>

        </LinearLayout>

        <!-- Kanan: Card Form -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Dosen"
                    android:textSize="11sp"
                    android:textColor="#1A5C3A"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etNamaDosen"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:hint="Masukkan nama dosen"
                    android:textColor="#1A5C3A"
                    android:textSize="12sp"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/bg_input_mint"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Semester"
                    android:textSize="11sp"
                    android:textColor="#1A5C3A"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <Spinner
                    android:id="@+id/spinnerSemester"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_input_mint"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jumlah Mahasiswa"
                    android:textSize="11sp"
                    android:textColor="#1A5C3A"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etJumlahMahasiswa"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:hint="Contoh: 30"
                    android:textColor="#1A5C3A"
                    android:textSize="12sp"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/bg_input_mint"
                    android:layout_marginBottom="14dp"/>

                <Button
                    android:id="@+id/btnGenerate"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Mulai Generate"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:backgroundTint="#34C17A"
                    android:stateListAnimator="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>