<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAF5"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="#F0FAF5"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Lingkaran besar kiri atas - lebih ke dalam agar tidak terpotong -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/bg_circle_green"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true"
                android:layout_marginTop="0dp"
                android:layout_marginStart="0dp"
                android:alpha="0.22"/>

            <!-- Lingkaran kanan - full tidak terpotong -->
            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_circle_green"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="32dp"
                android:layout_marginTop="80dp"
                android:alpha="0.22"/>

            <!-- Lingkaran kecil kiri bawah -->
            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_mint"
                android:layout_marginStart="24dp"
                android:layout_marginTop="180dp"
                android:alpha="0.30"/>

            <!-- Teks Header -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="28dp"
                android:layout_marginTop="60dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pemrograman Seluler"
                    android:textSize="10sp"
                    android:textColor="#1D8A56"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_green"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lembar&#10;Penilaian"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:textColor="#1A5C3A"
                    android:lineSpacingMultiplier="1.1"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generator otomatis untuk kelas Anda"
                    android:textSize="12sp"
                    android:textColor="#5D9E7A"/>

            </LinearLayout>
        </RelativeLayout>

        <!-- Card Form -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Dosen"
                    android:textSize="12sp"
                    android:textColor="#1A5C3A"
                    android:textStyle="bold"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/etNamaDosen"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Masukkan nama dosen"
                    android:textColor="#1A5C3A"
                    android:textSize="13sp"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_input_mint"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Semester"
                    android:textSize="12sp"
                    android:textColor="#1A5C3A"
                    android:textStyle="bold"
                    android:layout_marginBottom="5dp"/>

                <Spinner
                    android:id="@+id/spinnerSemester"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input_mint"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jumlah Mahasiswa"
                    android:textSize="12sp"
                    android:textColor="#1A5C3A"
                    android:textStyle="bold"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/etJumlahMahasiswa"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Contoh: 30"
                    android:textColor="#1A5C3A"
                    android:textSize="13sp"
                    android:inputType="number"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_input_mint"
                    android:layout_marginBottom="20dp"/>

                <Button
                    android:id="@+id/btnGenerate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Mulai Generate"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:backgroundTint="#34C17A"
                    android:stateListAnimator="@null"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Data akan dikirim ke panel generator"
                    android:textSize="11sp"
                    android:textColor="#7DBF9A"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>